# Apres installation, .env.local contient typiquement :
# DATABASE_URL=
# ENCRYPTION_KEY=64_hex_chars
# AUTH_SECRET=
# NONCE_SALT=
# SECURE_AUTH_SALT=
# SAAS_INSTALLED=true
# AUTH_URL=https://votre-domaine.com   # optionnel prod

# --- API agent / MCP (Phase E) : automates hors navigateur
# Jeton secret (min. 32 caracteres) ; meme valeur dans mcp-server
# SAAS_OS_AGENT_API_TOKEN=
# UUID du praticien dont le contenu peut etre lu/écrit avec ce jeton
# SAAS_OS_AGENT_PRACTITIONER_ID=
# Par defaut false : l'agent ne peut pas fusionner le theme global via POST cms-bundle
# SAAS_OS_AGENT_ALLOW_THEME=false

# Avant premiere install : laisser vide ou ne pas definir SAAS_INSTALLED
# Le site redirige vers /install
